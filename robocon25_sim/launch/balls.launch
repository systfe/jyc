<launch>

  <!-- these are the arguments you can pass this launch file, for example paused:=true -->
  <arg name="paused" default="false"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="gui" default="true"/>
  <arg name="headless" default="false"/>
  <arg name="debug" default="false"/> 
  <arg name="verbose" default="false"/>

  <!-- We resume the logic in empty_world.launch, changing only the name of the world to be launched -->
  <include file="$(find-pkg-share robocon25_sim)/launch/gazebo_no_eol.launch.py">
    <arg name="world" value="$(find-pkg-share robocon25_sim)/worlds/robocon25.world"/>
    <arg name="verbose" value="$(var verbose)"/>
    <arg name="paused" value="$(var paused)"/>
    <arg name="gui" value="$(var gui)"/>
  </include>
  
  <!-- Spawn a robot into Gazebo -->
  <node name="spawn_urdf" pkg="gazebo_ros" exec="spawn_entity.py" args="-file $(find-pkg-share robocon25_sim)/models/robot.model -entity robot" />
  <node name="red_ball_1" pkg="gazebo_ros" exec="spawn_entity.py" args="-file $(find-pkg-share robocon25_sim)/models/red_ball.model -x 1.0  -entity red_ball_1" />

  <node name="red_ball_2" pkg="gazebo_ros" exec="spawn_entity.py" args="-file $(find-pkg-share robocon25_sim)/models/red_ball.model -x 2.0  -entity red_ball_2" />
  <node name="red_ball_3" pkg="gazebo_ros" exec="spawn_entity.py" args="-file $(find-pkg-share robocon25_sim)/models/red_ball.model -x 3.0  -entity red_ball_3" />
  <node name="red_ball_4" pkg="gazebo_ros" exec="spawn_entity.py" args="-file $(find-pkg-share robocon25_sim)/models/red_ball.model -x 4.0  -entity red_ball_4" />
  <node name="red_ball_5" pkg="gazebo_ros" exec="spawn_entity.py" args="-file $(find-pkg-share robocon25_sim)/models/red_ball.model -x 5.0  -entity red_ball_5" />

  <node name="rqt_image_view" pkg="rqt_image_view" exec="rqt_image_view" required="true"/>

</launch>

